<Window x:Class="LocalSearchLauncher.MainWindow"
 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
 Width="820" Height="600" WindowStyle="None" ResizeMode="NoResize" AllowsTransparency="True"
 Background="Transparent" ShowInTaskbar="False" Topmost="True" WindowStartupLocation="CenterScreen"
 PreviewKeyDown="Window_PreviewKeyDown">
 <Border CornerRadius="18" Background="#F20F172A" BorderBrush="#553B82F6" BorderThickness="1" Padding="18">
  <Border.Effect><DropShadowEffect BlurRadius="32" ShadowDepth="8" Opacity="0.55" Color="#000000"/></Border.Effect>
  <Grid>
   <Grid x:Name="SearchView"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
    <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
     <TextBox x:Name="QueryBox" FontFamily="Inter, Segoe UI" FontSize="21" Foreground="#F8FAFC" Background="#CC1E293B" BorderBrush="#3B82F6" BorderThickness="1" Padding="14,10" TextChanged="QueryBox_TextChanged"/>
     <Button Grid.Column="1" Content="GUI" Margin="10,0,0,0" Padding="16,8" Click="OpenGui_Click"/>
     <CheckBox x:Name="GanttCheck" Grid.Column="2" Content="gantt" Foreground="#E2E8F0" VerticalAlignment="Center" Margin="14,0,4,0" Click="GanttCheck_Click"/>
    </Grid>
    <ListBox x:Name="Results" Grid.Row="1" Margin="0,14,0,10" Background="Transparent" BorderThickness="0" Foreground="#E2E8F0" FontFamily="Inter, Segoe UI" FontSize="15" MouseDoubleClick="Results_MouseDoubleClick">
     <ListBox.ItemContainerStyle><Style TargetType="ListBoxItem"><Setter Property="HorizontalContentAlignment" Value="Stretch"/><Setter Property="Margin" Value="0,2"/></Style></ListBox.ItemContainerStyle>
     <ListBox.ItemTemplate><DataTemplate><Border Padding="12,9" Background="#991E293B" CornerRadius="9">
      <Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
       <TextBlock Text="{Binding FileName}" FontWeight="SemiBold" Foreground="#F8FAFC"/>
       <TextBlock Grid.Row="1" Text="{Binding FullPath}" Foreground="#60A5FA" FontSize="11" TextTrimming="CharacterEllipsis"/>
       <TextBlock Grid.Row="2" Text="{Binding PlainSnippet}" Foreground="#94A3B8" FontSize="12" TextTrimming="CharacterEllipsis" MaxHeight="40"/>
       <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,7,0,0">
        <Button Content="パスをコピー" Margin="4,0" Padding="8,3" Click="CopyPath_Click"/>
        <Button Content="保存場所" Margin="4,0" Padding="8,3" Click="Reveal_Click"><Button.Style><Style TargetType="Button"><Setter Property="Visibility" Value="Visible"/><Style.Triggers><DataTrigger Binding="{Binding IsGantt}" Value="True"><Setter Property="Visibility" Value="Collapsed"/></DataTrigger></Style.Triggers></Style></Button.Style></Button>
        <Button Content="フォルダを開く" Margin="4,0" Padding="8,3" Click="OpenFolder_Click"><Button.Style><Style TargetType="Button"><Setter Property="Visibility" Value="Visible"/><Style.Triggers><DataTrigger Binding="{Binding IsGantt}" Value="True"><Setter Property="Visibility" Value="Collapsed"/></DataTrigger></Style.Triggers></Style></Button.Style></Button>
        <Button Content="ganttのリンクを開く" Margin="4,0" Padding="8,3" Click="OpenGanttLink_Click"><Button.Style><Style TargetType="Button"><Setter Property="Visibility" Value="Collapsed"/><Style.Triggers><DataTrigger Binding="{Binding HasGanttLink}" Value="True"><Setter Property="Visibility" Value="Visible"/></DataTrigger></Style.Triggers></Style></Button.Style></Button>
       </StackPanel>
      </Grid>
     </Border></DataTemplate></ListBox.ItemTemplate>
    </ListBox>
    <TextBlock x:Name="Status" Grid.Row="2" Foreground="#94A3B8" FontSize="12" Text="Shift × 2 で表示・非表示　Tabでganttメモ　Escで閉じる"/>
   </Grid>
   <Grid x:Name="MemoView" Visibility="Collapsed" KeyboardNavigation.TabNavigation="Cycle">
    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
    <Grid><TextBlock Text="gantt メモ" Foreground="#F8FAFC" FontSize="16" FontWeight="Bold"/><TextBlock x:Name="ParentLabel" Text="parent: 0" HorizontalAlignment="Right" Foreground="#93C5FD"/></Grid>
    <TextBox x:Name="MemoTitle" Grid.Row="1" Margin="0,14,0,10" Padding="12,9" FontSize="16" Background="#CC1E293B" Foreground="#F8FAFC" BorderBrush="#3B82F6" Text="" ToolTip="タスク名を入力してください..."/>
    <TextBox x:Name="MemoBody" Grid.Row="2" Padding="12" FontSize="14" Background="#CC1E293B" Foreground="#F8FAFC" BorderBrush="#334155" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" ToolTip="メモを入力してください..."/>
    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,8"><Button x:Name="MemoCancel" Content="キャンセル" Padding="18,7" Margin="4,0" Click="MemoCancel_Click"/><Button x:Name="MemoSubmit" Content="送信" Padding="24,7" Margin="4,0" Click="MemoSubmit_Click"/></StackPanel>
    <TextBlock x:Name="MemoStatus" Grid.Row="4" Foreground="#94A3B8" Text="Enterは改行／入力継続　送信は送信ボタンから"/>
   </Grid>
  </Grid>
 </Border>
</Window>
